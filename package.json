{
  "name": "blackice-policy-router",
  "version": "0.1.25",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible policy/router server for OpenClaw backed by Ollama",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prestart": "pnpm run build",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:unit": "vitest run src/log.test.ts src/http/requestLogging.test.ts",
    "test:integration": "vitest run src/routes.integration.test.ts",
    "test:watch": "vitest",
    "version:patch": "pnpm version patch -m \"chore(release): %s\"",
    "version:minor": "pnpm version minor -m \"chore(release): %s\"",
    "version:major": "pnpm version major -m \"chore(release): %s\"",
    "tag:change": "node scripts/tag-change.mjs"
  },
  "engines": {
    "node": ">=18.17"
  },
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "ai": "^5.0.0",
    "express": "^4.21.2",
    "ollama-ai-provider-v2": "1.5.2",
    "yaml": "^2.8.2",
    "zod": "^4.0.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
